{
  "name": "esm-sync",
  "version": "3.3.6",
  "description": "Tomorrow's ECMAScript modules today!",
  "license": "MIT",
  "author": "Khiet Tam Nguyen",
  "scripts": {
    "prelint": "pnpm pretest",
    "prepare": "husky",
    "prepub": "pnpm test:prod && pnpm build:prod",
    "prepublishOnly": "pnpm build:prod",
    "pretest": "pnpm build --test",
    "pretest:prod": "pnpm build:prod --test",
    "build": "node script/build.js",
    "build:prod": "pnpm build --prod",
    "clean": "node script/clean.js",
    "lint": "eslint '**/*.{js,mjs}' --fix --quiet",
    "pub": "node script/publish.js",
    "test": "node script/test.js",
    "test:prod": "node script/test.js --prod"
  },
  "main": "esm.js",
  "types": "index.d.ts",
  "private": false,
  "runkitExample": "require = require(\"esm-sync\")(module)\nrequire(\"lodash-es\")",
  "esm": true,
  "engines": {
    "node": ">=6"
  },
  "keywords": [
    "commonjs",
    "ecmascript",
    "export",
    "import",
    "modules",
    "node",
    "require"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nktnet1/esm-sync"
  },
